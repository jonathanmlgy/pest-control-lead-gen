    {
      "parameters": {
        "promptType": "define",
        "text": "=={{ 'Qualify this business as a pest control lead:\\n\\nBusiness Name: ' + ($('Loop Over Items').item.json.title || 'N/A') + '\\nCategory: ' + ($('Loop Over Items').item.json.category || 'N/A') + '\\nAddress: ' + ($('Loop Over Items').item.json.address || 'N/A') + '\\nPhone: ' + ($('Loop Over Items').item.json.phone || 'N/A') + '\\nRating: ' + ($('Loop Over Items').item.json.total_score || 'N/A') + '\\nReviews: ' + ($('Loop Over Items').item.json.reviews_count || 'N/A') + '\\nWebsite: ' + ($('Loop Over Items').item.json.website || 'N/A') + '\\nEmail: ' + ($('Loop Over Items').item.json.email || 'N/A') }}",
        "options": {
          "systemMessage": "You are a lead qualification assistant for a pest control business in the Philippines.\n\nDetermine category from the business name:\n- If name contains \"restaurant\", \"cafe\", \"fast food\", \"eatery\" → category = restaurant\n- If name contains \"office\", \"corporate\" → category = office\n- If name contains \"warehouse\", \"storage\" → category = warehouse\n- Otherwise → category = other\n\nGive the lead a score using these rules:\n- Score 8-10 (hot): restaurants, food businesses, warehouses, hotels, schools, hospitals\n- Score 5-7 (warm): offices, retail stores, commercial buildings\n- Score 1-4 (cold): sari-sari stores, solo practitioners, residential, online-only\n\nGive additional score if:\n- Has a phone number (+2 points)\n- Has 10+ reviews (+1 point)\n- Rating above 4.0 (+1 point)\n- Has a website (+1 point)\n\nCategory must be one of: restaurant, warehouse, office, hotel, school, hospital, retail, other\nStatus must be exactly: \"hot\", \"warm\", or \"cold\"\n\nReturn ONLY this JSON format, nothing else:\n{\"score\": 7, \"reason\": \"One sentence reason here\", \"status\": \"warm\", \"category\": \"restaurant\"}"
        }
      },
      "type": "@n8n/n8n-nodes-langchain.agent",
      "typeVersion": 3.1,
      "position": [
        -1408,
