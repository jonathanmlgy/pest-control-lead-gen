    {
      "parameters": {
        "jsCode": "try {\n  const output = $json.output;\n  \n  // Clean and parse JSON from agent output\n  const cleaned = output.replace(/```json|```/g, '').trim();\n  const parsed = JSON.parse(cleaned);\n  \n  return [\n    {\n      json: {\n        business_name: $('Loop Over Items').item.json.title,\n        address: $('Loop Over Items').item.json.address,\n        phone: $('Loop Over Items').item.json.phone,\n        website: $('Loop Over Items').item.json.website,\n        rating: Number($('Loop Over Items').item.json.total_score || 0),\n        reviews_count: Number($('Loop Over Items').item.json.reviews_count || 0),\n        ai_score: Number(parsed.score),\n        ai_reason: parsed.reason,\n        status: parsed.status,\n        category: parsed.category,\n        search_text: `${$('Loop Over Items').item.json.title} is a ${parsed.category} located in ${$('Loop Over Items').item.json.city || $('Loop Over Items').item.json.state || ''}. This business has ${$('Loop Over Items').item.json.reviews_count || 0} reviews and a rating of ${$('Loop Over Items').item.json.total_score || 'unrated'}. As a ${parsed.category}, this establishment ${\n          parsed.category === 'restaurant' ? 'handles food and has high hygiene requirements' : \n          parsed.category === 'warehouse' ? 'stores goods and needs rodent control' : \n          parsed.category === 'office' ? 'has many employees and needs clean workspace' : \n          'requires pest control services'\n        }. Lead status: ${parsed.status}. AI qualification reason: ${parsed.reason || ''}`\n      }\n    }\n  ];\n\n} catch(error) {\n  // Fallback — don't crash the workflow\n  const lead = $('Loop Over Items').item.json;\n  return [\n    {\n      json: {\n        business_name: lead.title || 'Unknown Business',\n        address: lead.address || '',\n        phone: lead.phone || '',\n        website: lead.website || '',\n        rating: Number(lead.total_score || 0),\n        reviews_count: Number(lead.reviews_count || 0),\n        ai_score: 0,\n        ai_reason: 'Parse error: ' + error.message,\n        status: 'error',\n        category: 'unknown',\n        search_text: `${lead.title || 'Unknown'} is a business requiring pest control services located in ${lead.city || lead.state || 'Philippines'}`\n      }\n    }\n  ];\n}"
      },
